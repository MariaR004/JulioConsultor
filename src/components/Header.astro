---
import type { ContactSettings } from "@/types";
import { DEFAULT_CONTACT, defaultWhatsappText } from "@/lib/format";
import { legacyWhatsappBase } from "@/lib/viewModel";

type Props = {
  scrolled?: boolean;
  contact?: ContactSettings;
};

const { scrolled = false, contact } = Astro.props;
const waHref = `${legacyWhatsappBase(contact ?? DEFAULT_CONTACT)}?text=${encodeURIComponent(defaultWhatsappText())}`;
---

<header class:list={["site-header", { scrolled }]} id="siteHeader">
  <div class="container header-inner">
    <a href="/#inicio" class="brand" aria-label="Júlio Consultor Imobiliário - início">
      <img
        src="/img/logo-nova-sem-fundo.png"
        alt="Júlio Consultor Imobiliário"
        class="brand-logo-img"
      />
    </a>

    <nav class="main-nav" id="mainNav" aria-label="Navegação principal">
      <ul>
        <li><a href="/#inicio" class="nav-link active">Início</a></li>
        <li><a href="/#destaque" class="nav-link">Destaque</a></li>
        <li><a href="/#imoveis" class="nav-link">Imóveis</a></li>
        <li><a href="/#sobre" class="nav-link">Sobre</a></li>
        <li><a href="/#contato" class="nav-link">Contato</a></li>
      </ul>
      <a
        class="btn btn-whatsapp nav-cta"
        id="headerWhatsapp"
        href={waHref}
        target="_blank"
        rel="noopener"
      >
        <svg class="ico" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path
            fill="currentColor"
            d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm5.8 14.16c-.25.69-1.46 1.34-2 1.42-.51.07-1.16.1-1.87-.12-.43-.13-.99-.32-1.7-.63-2.99-1.29-4.95-4.3-5.1-4.5-.15-.2-1.22-1.62-1.22-3.09s.77-2.19 1.05-2.49c.27-.3.59-.37.79-.37l.57.01c.18 0 .43-.07.67.51.25.6.85 2.07.92 2.22.07.15.12.32.02.52-.1.2-.15.32-.3.5-.15.17-.31.39-.45.52-.15.15-.3.31-.13.61.17.3.76 1.25 1.63 2.02 1.12.99 2.06 1.3 2.36 1.45.3.15.47.12.65-.07.18-.2.74-.86.94-1.16.2-.3.4-.25.67-.15.27.1 1.71.81 2.01.96.3.15.5.22.57.35.07.12.07.72-.18 1.41Z"
          ></path>
        </svg>
        WhatsApp
      </a>
    </nav>

    <button
      class="hamburger"
      id="hamburger"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="mainNav"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    height: var(--header-h);
    background: rgba(255, 255, 255, 0.86);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid transparent;
    transition:
      height var(--transition),
      box-shadow var(--transition),
      background var(--transition),
      border-color var(--transition);
  }

  .site-header.scrolled {
    height: 72px;
    box-shadow: var(--shadow-sm);
    background: rgba(255, 255, 255, 0.96);
    border-bottom-color: var(--border);
  }

  .header-inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .site-header .brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    text-decoration: none;
  }

  .brand-logo-img {
    display: block;
    height: calc(100% - 12px);
    width: auto;
    max-height: none;
    max-width: min(230px, 52vw);
    filter: drop-shadow(0 4px 8px rgba(16, 24, 40, 0.1));
    transition:
      height var(--transition),
      transform var(--transition);
  }

  .site-header .brand:hover .brand-logo-img {
    transform: translateY(-2px);
  }

  .site-header.scrolled .brand-logo-img {
    height: calc(100% - 10px);
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .main-nav ul {
    display: flex;
    gap: 6px;
  }

  .nav-link {
    position: relative;
    font-family: var(--ff-head);
    font-weight: 600;
    color: var(--text);
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 0.98rem;
    transition: color var(--transition);
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 2px;
    height: 3px;
    background: var(--yellow);
    border-radius: 3px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition);
  }

  .nav-link:hover {
    color: var(--blue);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    transform: scaleX(1);
  }

  .nav-link.active {
    color: var(--blue);
  }

  .nav-cta {
    margin-left: 4px;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 46px;
    height: 46px;
    padding: 10px;
    background: var(--offwhite);
    border: 1px solid var(--border);
    border-radius: 12px;
    cursor: pointer;
  }

  .hamburger span {
    display: block;
    height: 3px;
    width: 100%;
    background: var(--text);
    border-radius: 3px;
    transition:
      transform var(--transition),
      opacity var(--transition);
  }

  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }

  .hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  @media (max-width: 860px) {
    .hamburger {
      display: flex;
    }

    .main-nav {
      position: fixed;
      inset: var(--header-h) 0 auto 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--white);
      border-bottom: 1px solid var(--border);
      box-shadow: var(--shadow);
      padding: 12px 22px 22px;
      transform: translateY(-130%);
      opacity: 0;
      visibility: hidden;
      transition:
        transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
        opacity 0.3s ease,
        visibility 0.3s;
      max-height: calc(100svh - var(--header-h));
      overflow-y: auto;
    }

    .main-nav.open {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
    }

    .main-nav ul {
      flex-direction: column;
      gap: 2px;
    }

    .nav-link {
      display: block;
      padding: 14px 12px;
      border-radius: 10px;
      font-size: 1.05rem;
    }

    .nav-link::after {
      display: none;
    }

    .nav-link:hover,
    .nav-link.active {
      background: var(--yellow-soft);
    }

    .nav-cta {
      margin-top: 12px;
      width: 100%;
    }
  }

  @media (max-width: 560px) {
    .site-header.scrolled {
      height: 56px;
    }

    .brand-logo-img {
      max-width: min(210px, 54vw);
    }

    .hamburger {
      flex: 0 0 46px;
    }
  }
</style>
