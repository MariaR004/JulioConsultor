{
  "name": "corretor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "astro build",
    "preview": "astro preview --host 127.0.0.1",
    "astro": "astro",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "check": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "optimize:images": "node scripts/optimize-images.mjs",
    "security:public-artifacts": "node scripts/check-public-artifacts.mjs",
    "validate": "npm run lint && npm run format:check && npm run typecheck && npm run check && npm run test && npm run security:public-artifacts",
    "storage:cleanup-orphans": "node scripts/cleanup-orphan-property-photos.mjs"
  },
  "overrides": {
    "yaml": "^2.8.3"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.6.1",
    "@lucide/astro": "^1.17.0",
    "@supabase/supabase-js": "^2.49.8",
    "astro": "^6.4.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "0.34.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
